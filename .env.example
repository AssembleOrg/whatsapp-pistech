PORT=3000
NODE_ENV=development

# Auth directory - in Railway use the volume path (e.g., /data/auth_info)
AUTH_DIR=./auth_info

# API key for messaging endpoints (min 8 chars)
API_KEY=your-api-key-here

# Password for QR page (min 4 chars)
QR_PASSWORD=your-qr-password

# Comma-separated group JIDs that are allowed to receive messages
# Use GET /api/groups to find group JIDs
WHITELISTED_GROUPS=

# Comma-separated origins for CORS (use * for all)
ALLOWED_ORIGINS=*

# Message delay between sends (ms)
MESSAGE_DELAY_MIN=15000
MESSAGE_DELAY_MAX=25000

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=20
